{
  "name" : "ingest_sales_data",
  "jobMode" : "SCRIPT",
  "description" : "This AWS glue Visual ETL pipeline is used to ingest and clean data and convert the input data files from csv to parquet files ",
  "role" : "arn:aws:iam::406868976171:role/AWSGlueRole",
  "executionProperty" : {
    "maxConcurrentRuns" : 1
  },
  "command" : {
    "name" : "glueetl",
    "scriptLocation" : "s3://aws-glue-assets-406868976171-ap-south-1/scripts/ingest_sales_data.py",
    "pythonVersion" : "3"
  },
  "defaultArguments" : {
    "--enable-metrics" : "true",
    "--spark-event-logs-path" : "s3://aws-glue-assets-406868976171-ap-south-1/sparkHistoryLogs/",
    "--enable-job-insights" : "true",
    "--enable-observability-metrics" : "true",
    "--conf" : "spark.eventLog.rolling.enabled=true",
    "--enable-glue-datacatalog" : "true",
    "--job-bookmark-option" : "job-bookmark-enable",
    "--job-language" : "python",
    "--TempDir" : "s3://aws-glue-assets-406868976171-ap-south-1/temporary/"
  },
  "maxRetries" : 0,
  "allocatedCapacity" : 10,
  "timeout" : 480,
  "maxCapacity" : 10.0,
  "glueVersion" : "5.0",
  "numberOfWorkers" : 10,
  "workerType" : "G.1X",
  "executionClass" : "STANDARD",
  "sourceControlDetails" : {
    "provider" : "GITHUB",
    "repository" : "AWS_Data_ingestion_ETL_POC",
    "branch" : "main",
    "folder" : "visual_ETL"
  }
}